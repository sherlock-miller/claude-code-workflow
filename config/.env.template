# Claude Code Workflow Environment Variables
# This file is sourced by .bashrc to set API keys
# DO NOT commit this file to git or share it!

# DeepSeek API Key (Required - for Claude Code AI backend)
# Get your key at: https://platform.deepseek.com/api_keys
ANTHROPIC_API_KEY={{DEEPSEEK_API_KEY}}

# Doubao/ARK API Key (Optional - for multimodal vision tools)
# Get your key at: https://console.volcengine.com/ark
ARK_API_KEY={{ARK_API_KEY}}

# Edge CDP URL (default: http://127.0.0.1:9224)
EDGE_CDP_URL=http://127.0.0.1:9224
